{
  "info": {
    "_postman_id": "6d419928-52f5-4b18-90d0-4a5ca3b9f4d8",
    "name": "API Gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "testEmail",
      "value": ""
    },
    {
      "key": "testPassword",
      "value": "Password123"
    },
    {
      "key": "testUsername",
      "value": ""
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Gateway Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Unauthorized Me",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 401', function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Unauthorized payload is returned', function () {",
              "  pm.expect(json.status).to.eql('error');",
              "  pm.expect(json.message).to.eql('Unauthorized');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const suffix = Date.now().toString();",
              "pm.collectionVariables.set('testEmail', `gateway-${suffix}@example.com`);",
              "pm.collectionVariables.set('testUsername', `gateway_${suffix}`);",
              "pm.collectionVariables.set('accessToken', '');",
              "pm.collectionVariables.set('refreshToken', '');",
              "pm.collectionVariables.set('userId', '');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Register returns a user id', function () {",
              "  pm.expect(json.status).to.eql('success');",
              "  pm.expect(json.data.user.id).to.be.a('string').and.not.empty;",
              "});",
              "pm.collectionVariables.set('userId', pm.response.json().data.user.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"username\": \"{{testUsername}}\",\n  \"nickname\": \"Gateway\",\n  \"bio\": \"Profil cree via la gateway\",\n  \"url_photo\": \"https://example.com/avatar.png\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "04 - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('accessToken', json.data.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
              "pm.collectionVariables.set('userId', json.data.user.id);",
              "pm.test('Tokens are stored', function () {",
              "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
              "  pm.expect(json.data.refreshToken).to.be.a('string').and.not.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 - Verify Token",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/verify",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "verify"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "06 - Auth Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Auth me returns same user id', function () {",
              "  pm.expect(json.data.user.id).to.eql(pm.collectionVariables.get('userId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "07 - Get User State",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{userId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Default role and statuts exist', function () {",
              "  pm.expect(json.data.role).to.eql('USER');",
              "  pm.expect(json.data.statuts).to.eql('ACTIVE');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "08 - Get Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/profiles/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "profiles",
            "{{userId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Profile returns generated username', function () {",
              "  pm.expect(json.data.id_user).to.eql(pm.collectionVariables.get('userId'));",
              "  pm.expect(json.data.username).to.eql(pm.collectionVariables.get('testUsername'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "09 - Gateway Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Gateway me aggregates auth, user and profile', function () {",
              "  pm.expect(json.status).to.eql('success');",
              "  pm.expect(json.data.auth.id).to.eql(pm.collectionVariables.get('userId'));",
              "  pm.expect(json.data.user.id_user).to.eql(pm.collectionVariables.get('userId'));",
              "  pm.expect(json.data.profile.id_user).to.eql(pm.collectionVariables.get('userId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
